{
  "name": "@tavosud/sky-notifications",
  "version": "1.0.0",
  "description": "Lightweight zero-dependency toast notification library for React",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tavosud/sky-notifications.git"
  },
  "homepage": "https://github.com/tavosud/sky-notifications#readme",
  "bugs": {
    "url": "https://github.com/tavosud/sky-notifications/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --minify --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "tsc"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
